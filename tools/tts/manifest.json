  "gender": "f"
 },
 {
  "id": "dlg_g15_1a",
  "text": "לֹא, אֲנִי לֹא רוֹצֶה עוֹף.",
  "file": "dlg_g15_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_g15_2q",
  "text": "אַתְּ הוֹלֶכֶת?",
