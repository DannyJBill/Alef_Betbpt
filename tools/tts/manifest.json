  "file": "r1_m29_03.mp3"
 },
 {
  "id": "r1_g21_01",
  "text": "הוֹלְכִים",
  "file": "r1_g21_01.mp3"
 },
 {
  "id": "r1_g21_02",
  "text": "אוֹכְלִים",
  "file": "r1_g21_02.mp3"
 },
 {
  "id": "r1_g21_03",
  "text": "גָּרִים",
  "file": "r1_g21_03.mp3"
 },
 {
  "id": "r1_g21_04",
  "text": "אֲנַחְנוּ הוֹלְכִים",
  "file": "r1_g21_04.mp3"
 },
 {
  "id": "r1_g21_05",
  "text": "הֵם גָּרִים בָּעִיר",
  "file": "r1_g21_05.mp3"
 },
 {
  "id": "r1_g22_01",
  "text": "הֵן",
  "file": "r1_g22_01.mp3"
 },
 {
  "id": "r1_g22_02",
  "text": "הוֹלְכוֹת",
  "file": "r1_g22_02.mp3"
 },
 {
  "id": "r1_g22_03",
  "text": "אוֹכְלוֹת",
  "file": "r1_g22_03.mp3"
 },
 {
  "id": "r1_g22_04",
  "text": "הֵן הוֹלְכוֹת לָעִיר",
  "file": "r1_g22_04.mp3"
 },
 {
  "id": "r1_g23_01",
  "text": "שׁוֹתִים",
  "file": "r1_g23_01.mp3"
 },
 {
  "id": "r1_g23_02",
  "text": "רוֹצִים",
  "file": "r1_g23_02.mp3"
 },
 {
  "id": "r1_g23_03",
  "text": "אֲנַחְנוּ רוֹצִים מַיִם",
  "file": "r1_g23_03.mp3"
 },
 {
  "id": "r1_g24_01",
  "text": "יוֹדְעִים",
  "file": "r1_g24_01.mp3"
 },
 {
  "id": "r1_g24_02",
  "text": "יְכוֹלִים",
  "file": "r1_g24_02.mp3"
 },
 {
  "id": "r1_g24_03",
  "text": "אוֹהֲבִים",
  "file": "r1_g24_03.mp3"
 },
 {
  "id": "r1_g24_04",
  "text": "אֲנַחְנוּ אוֹהֲבִים אֶת הָעִיר",
  "file": "r1_g24_04.mp3"
 },
 {
  "id": "r1_g24_05",
  "text": "הֵם יוֹדְעִים עִבְרִית",
  "file": "r1_g24_05.mp3"
 },
 {
  "id": "r1_c4_01",
  "text": "הַכֶּלֶב שֶׁאֲנִי אוֹהֵב",
  "file": "r1_c4_01.mp3"
 },
 {
  "id": "r1_c4_02",
  "text": "הָעוּגָה שֶׁאֲנִי אוֹכֵל",
  "file": "r1_c4_02.mp3"
 },
 {
  "id": "r1_c4_03",
  "text": "הַיְּלָדִים שֶׁגָּרִים בָּעִיר",
  "file": "r1_c4_03.mp3"
 },
 {
  "id": "r1_ch21_01",
  "text": "אַחַת עֶשְׂרֵה",
  "file": "r1_ch21_01.mp3"
 },
 {
  "id": "r1_ch21_02",
  "text": "שְׁתֵּים עֶשְׂרֵה",
  "file": "r1_ch21_02.mp3"
 },
 {
  "id": "r1_ch21_03",
  "text": "שְׁלֹשׁ עֶשְׂרֵה",
  "file": "r1_ch21_03.mp3"
 },
 {
  "id": "r1_ch21_04",
  "text": "חֲמֵשׁ עֶשְׂרֵה",
  "file": "r1_ch21_04.mp3"
 },
 {
  "id": "r1_ch21_05",
  "text": "עֶשְׂרִים",
  "file": "r1_ch21_05.mp3"
 },
 {
  "id": "pl_01",
  "text": "זֶה טוֹב",
  "file": "pl_01.mp3"
 },
 {
  "id": "pl_02",
  "text": "זֶה לֹא טוֹב",
  "file": "pl_02.mp3"
 },
 {
  "id": "pl_03",
  "text": "חַג שָׂמֵחַ!",
  "file": "pl_03.mp3"
 },
 {
  "id": "pl_04",
  "text": "אֲנִי רוֹצֶה מַיִם",
  "file": "pl_04.mp3"
 },
 {
  "id": "pl_05",
  "text": "אֲנִי הוֹלֵךְ",
  "file": "pl_05.mp3"
 },
 {
  "id": "pl_06",
  "text": "אִימָא בָּאָה",
  "file": "pl_06.mp3"
 },
 {
  "id": "pl_07",
  "text": "אַבָּא אוֹכֵל לֶחֶם",
  "file": "pl_07.mp3"
 },
 {
  "id": "pl_08",
  "text": "?אַתָה רוֹצֶה מִיץ",
  "file": "pl_08.mp3"
 },
 {
  "id": "pl_09",
  "text": "כֵּן, אֲנִי רוֹצֶה",
  "file": "pl_09.mp3"
 },
 {
  "id": "pl_10",
  "text": "הִיא יַלְדָה",
  "file": "pl_10.mp3"
 },
 {
  "id": "pl_11",
  "text": "יֶלֶד אוֹכֵל תַּפּוּחַ",
  "file": "pl_11.mp3"
 },
 {
  "id": "pl_12",
  "text": "כֶּלֶב רוֹאֶה עוֹף",
  "file": "pl_12.mp3"
 },
 {
  "id": "pl_13",
  "text": "חָלָב חַם",
  "file": "pl_13.mp3"
 },
 {
  "id": "pl_14",
  "text": "מִיץ טָעִים",
  "file": "pl_14.mp3"
 },
 {
  "id": "pl_15",
  "text": "זֹאת אַהֲבָה",
  "file": "pl_15.mp3"
 },
 {
  "id": "pl_16",
  "text": "אֲנִי קוֹרֵא סֵפֶר",
  "file": "pl_16.mp3"
 }
]