  "id": "r1_ch21_02",
  "text": "שְׁתֵּים עֶשְׂרֵה",
  "file": "r1_ch21_02.mp3",
  "gender": "m"
 },
 {
  "id": "r1_ch21_03",
  "text": "שְׁלֹשׁ עֶשְׂרֵה",
  "file": "r1_ch21_03.mp3",
  "gender": "m"
 },
 {
  "id": "r1_ch21_04",
  "text": "חֲמֵשׁ עֶשְׂרֵה",
  "file": "r1_ch21_04.mp3",
  "gender": "m"
 },
 {
  "id": "r1_ch21_05",
  "text": "עֶשְׂרִים",
  "file": "r1_ch21_05.mp3",
  "gender": "m"
 },
 {
  "id": "pl_01",
  "text": "זֶה טוֹב",
  "file": "pl_01.mp3",
  "gender": "m"
 },
 {
  "id": "pl_02",
  "text": "זֶה לֹא טוֹב",
  "file": "pl_02.mp3",
  "gender": "m"
 },
 {
  "id": "pl_03",
  "text": "חַג שָׂמֵחַ!",
  "file": "pl_03.mp3",
  "gender": "m"
 },
 {
  "id": "pl_04",
  "text": "אֲנִי רוֹצֶה מַיִם",
  "file": "pl_04.mp3",
  "gender": "m"
 },
 {
  "id": "pl_05",
  "text": "אֲנִי הוֹלֵךְ",
  "file": "pl_05.mp3",
  "gender": "m"
 },
 {
  "id": "pl_06",
  "text": "אִימָא בָּאָה",
  "file": "pl_06.mp3",
  "gender": "f"
 },
 {
  "id": "pl_07",
  "text": "אַבָּא אוֹכֵל לֶחֶם",
  "file": "pl_07.mp3",
  "gender": "m"
 },
 {
  "id": "pl_08",
  "text": "?אַתָה רוֹצֶה מִיץ",
  "file": "pl_08.mp3",
  "gender": "m"
 },
 {
  "id": "pl_09",
  "text": "כֵּן, אֲנִי רוֹצֶה",
  "file": "pl_09.mp3",
  "gender": "m"
 },
 {
  "id": "pl_10",
  "text": "הִיא יַלְדָה",
  "file": "pl_10.mp3",
  "gender": "f"
 },
 {
  "id": "pl_11",
  "text": "יֶלֶד אוֹכֵל תַּפּוּחַ",
  "file": "pl_11.mp3",
  "gender": "m"
 },
 {
  "id": "pl_12",
  "text": "כֶּלֶב רוֹאֶה עוֹף",
  "file": "pl_12.mp3",
  "gender": "m"
 },
 {
  "id": "pl_13",
  "text": "חָלָב חַם",
  "file": "pl_13.mp3",
  "gender": "m"
 },
 {
  "id": "pl_14",
  "text": "מִיץ טָעִים",
  "file": "pl_14.mp3",
  "gender": "m"
 },
 {
  "id": "pl_15",
  "text": "זֹאת אַהֲבָה",
  "file": "pl_15.mp3",
  "gender": "f"
 },
 {
  "id": "pl_16",
  "text": "אֲנִי קוֹרֵא סֵפֶר",
  "file": "pl_16.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_1q",
  "text": "יֵשׁ לְךָ כֶּלֶב?",
  "file": "dlg_c1_1q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_1a",
  "text": "כֵּן, יֵשׁ לִי כֶּלֶב!",
  "file": "dlg_c1_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_2q",
  "text": "יֵשׁ לָךְ בַּיִת גָּדוֹל?",
  "file": "dlg_c1_2q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c1_2a",
  "text": "כֵּן, יֵשׁ לִי בַּיִת גָּדוֹל.",
  "file": "dlg_c1_2a.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c1_3q",
  "text": "יֵשׁ לוֹ יַלְדָּה?",
  "file": "dlg_c1_3q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_3a",
  "text": "כֵּן, יֵשׁ לוֹ יַלְדָּה — תָּמָר.",
  "file": "dlg_c1_3a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_4q",
  "text": "יֵשׁ לָהּ כֶּלֶב?",
  "file": "dlg_c1_4q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_4a",
  "text": "לֹא, אֵין לָהּ כֶּלֶב.",
  "file": "dlg_c1_4a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_g15_1q",
  "text": "אַתָּה רוֹצֶה עוֹף?",
  "file": "dlg_g15_1q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_g15_1a",
  "text": "לֹא, אֲנִי לֹא רוֹצֶה עוֹף.",
  "file": "dlg_g15_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_g15_2q",
  "text": "אַתְּ הוֹלֶכֶת?",
  "file": "dlg_g15_2q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_g15_2a",
  "text": "לֹא, אֲנִי לֹא הוֹלֶכֶת.",
  "file": "dlg_g15_2a.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_g15_3q",
  "text": "אַתָּה יוֹדֵעַ?",
  "file": "dlg_g15_3q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_g15_3a",
  "text": "אֲנִי לֹא יוֹדֵעַ...",
  "file": "dlg_g15_3a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_1q",
  "text": "אַתָּה אוֹכֵל?",
  "file": "dlg_c2_1q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c2_1a",
  "text": "כֵּן, אֲנִי אוֹכֵל.",
  "file": "dlg_c2_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_2q",
  "text": "אַתְּ רוֹצָה עוּגָה?",
  "file": "dlg_c2_2q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_2a",
  "text": "כֵּן, אֲנִי רוֹצָה!",
  "file": "dlg_c2_2a.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c2_3q",
  "text": "הוּא הוֹלֵךְ?",
  "file": "dlg_c2_3q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_3a",
  "text": "לֹא, הוּא לֹא הוֹלֵךְ.",
  "file": "dlg_c2_3a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_4q",
  "text": "יֵשׁ לְךָ מַיִם?",
  "file": "dlg_c2_4q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c2_4a",
  "text": "כֵּן, יֵשׁ לִי.",
  "file": "dlg_c2_4a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_m26_1q",
  "text": "אַתָּה מִתֵּל אָבִיב?",
  "file": "dlg_m26_1q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_m26_1a",
  "text": "לֹא, אֲנִי מֵרוּסְיָה.",
  "file": "dlg_m26_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c3_1q",
  "text": "יֵשׁ לָכֶם כֶּלֶב?",
  "file": "dlg_c3_1q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c3_1a",
  "text": "כֵּן, יֵשׁ לָנוּ כֶּלֶב — רֶקְס!",
  "file": "dlg_c3_1a.mp3",
  "gender": "m"
 }
]