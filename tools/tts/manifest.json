  "id": "ex_m22_4",
  "text": "יְלָדִים וְ... יְלָדוֹת",
  "file": "ex_m22_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m24_1",
  "text": "בְּבַיִת",
  "file": "ex_m24_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m24_2",
  "text": "בְּ + הַבַּיִת = בַּבַּיִת",
  "file": "ex_m24_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m24_4",
  "text": "בְּ + הָעִיר = בָּעִיר",
  "file": "ex_m24_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m24_5",
  "text": "הוּא גָּר בָּעִיר",
  "file": "ex_m24_5.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m25_1",
  "text": "לְ + הַבַּיִת = לַבַּיִת",
  "file": "ex_m25_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m25_3",
  "text": "הִיא הוֹלֶכֶת לָעִיר",
  "file": "ex_m25_3.mp3",
  "gender": "f"
 },
 {
  "id": "ex_m25_4",
  "text": "לְ + לִי, לְךָ, לוֹ…",
  "file": "ex_m25_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m26_3",
  "text": "מִ + הַבַּיִת = מֵהַבַּיִת",
  "file": "ex_m26_3.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m26_4",
  "text": "הִיא הוֹלֶכֶת מֵהָעִיר",
  "file": "ex_m26_4.mp3",
  "gender": "f"
 },
 {
  "id": "ex_c3_1",
  "text": "לִי · לְךָ · לָךְ · לוֹ · לָהּ",
  "file": "ex_c3_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m27_1",
  "text": "גָּדוֹל · גְּדוֹלָה · גְּדוֹלִים · גְּדוֹלוֹת",
  "file": "ex_m27_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m27_2",
  "text": "כֶּלֶב גָּדוֹל",
  "file": "ex_m27_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m27_5",
  "text": "עוּגוֹת גְּדוֹלוֹת",
  "file": "ex_m27_5.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m29_4",
  "text": "הוּא רוֹאֶה אֶת תָּמָר",
  "file": "ex_m29_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_m29_5",
  "text": "אֶת ≠ אַתְּ",
  "file": "ex_m29_5.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g21_4",
  "text": "הֵם אוֹכְלִים",
  "file": "ex_g21_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g21_5",
  "text": "הַיְּלָדִים גָּרִים בָּעִיר",
  "file": "ex_g21_5.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g22_4",
  "text": "מוֹרוֹת אוֹכְלוֹת",
  "file": "ex_g22_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g23_1",
  "text": "הוֹלֵךְ · הוֹלֶכֶת · הוֹלְכִים · הוֹלְכוֹת",
  "file": "ex_g23_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g23_2",
  "text": "שׁוֹתֶה · שׁוֹתָה · שׁוֹתִים · שׁוֹתוֹת",
  "file": "ex_g23_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g23_3",
  "text": "אֲנִי / אַתָּה / הוּא — הוֹלֵךְ",
  "file": "ex_g23_3.mp3",
  "gender": "m"
 },
 {
  "id": "ex_g24_3",
  "text": "הֵן יוֹשְׁבוֹת בַּבַּיִת",
  "file": "ex_g24_3.mp3",
  "gender": "f"
 },
 {
  "id": "ex_g24_4",
  "text": "אֲנַחְנוּ יְכוֹלִים!",
  "file": "ex_g24_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_c4_4",
  "text": "הָאִישׁ שֶׁקּוֹרֵא סֵפֶר",
  "file": "ex_c4_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_ch21_3",
  "text": "שְׁלֹשׁ עֶשְׂרֵה … תְּשַׁע עֶשְׂרֵה",
  "file": "ex_ch21_3.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d11_4",
  "text": "נְקֻדָּה",
  "file": "ex_d11_4.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d12_1",
  "text": "בַּיִת ↔ אָב",
  "file": "ex_d12_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d12_2",
  "text": "כֶּלֶב ↔ הוֹלֵךְ",
  "file": "ex_d12_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d12_3",
  "text": "פֹּה ↔ יָפֶה",
  "file": "ex_d12_3.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d13_1",
  "text": "הַ + בַּיִת = הַבַּיִת",
  "file": "ex_d13_1.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d13_2",
  "text": "הַ + כֶּלֶב = הַכֶּלֶב",
  "file": "ex_d13_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_d13_3",
  "text": "הַ + יֶלֶד = הַיֶּלֶד",
  "file": "ex_d13_3.mp3",
  "gender": "m"
 },
 {
  "id": "ex_sh11_1",
  "text": "מַלְכָּה",
  "file": "ex_sh11_1.mp3",
  "gender": "f"
 },
 {
  "id": "ex_sh11_2",
  "text": "יַלְדָּה",
  "file": "ex_sh11_2.mp3",
  "gender": "m"
 },
 {
  "id": "ex_sh12_3",
  "text": "מַלְכָּה ↔ שְׁלֹשָׁה",
  "file": "ex_sh12_3.mp3",
  "gender": "f"
 }
]