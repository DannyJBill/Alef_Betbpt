  "gender": "m"
 },
 {
  "id": "dlg_c1_4a",
  "text": "לֹא, אֵין לָהּ כֶּלֶב.",
  "file": "dlg_c1_4a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_g15_1q",
  "text": "אַתָּה רוֹצֶה עוֹף?",
