  "gender": "m"
 },
 {
  "id": "dlg_c1_1a",
  "text": "כֵּן, יֵשׁ לִי כֶּלֶב!",
  "file": "dlg_c1_1a.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_2q",
  "text": "יֵשׁ לָךְ בַּיִת גָּדוֹל?",
  "file": "dlg_c1_2q.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c1_2a",
  "text": "כֵּן, יֵשׁ לִי בַּיִת גָּדוֹל.",
  "file": "dlg_c1_2a.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c1_3q",
  "text": "יֵשׁ לוֹ יַלְדָּה?",
  "file": "dlg_c1_3q.mp3",
  "gender": "m"
 },
 {
  "id": "dlg_c1_3a",
  "text": "כֵּן, יֵשׁ לוֹ יַלְדָּה — תָּמָר.",
  "file": "dlg_c1_3a.mp3",
  "gender": "f"
 },
 {
  "id": "dlg_c1_4q",
  "text": "יֵשׁ לָהּ כֶּלֶב?",
